# Copy this file to .env before running docker compose.
#
# Public HTTP port exposed on the deployment host.
FRONTEND_BIND_IP=0.0.0.0
FRONTEND_PORT=8080

# External origins allowed by FastAPI CORS middleware.
# With the bundled nginx frontend, browser requests normally use /api on the same origin,
# but keep this accurate for direct API access and future reverse proxies.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# IANA timezone used by booking rules and seeded timestamps.
APP_TIME_ZONE=Europe/Moscow

# Required for persistent JWT signatures.
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret

# Required for the first seeded admin/manager/employee accounts when the DB is empty.
# Change these passwords from the admin UI immediately after first login.
DEFAULT_SEED_PASSWORD=replace-with-an-initial-strong-password

# SQLite database inside the backend container. Usually do not change this.
DATABASE_URL=sqlite:////data/parking.db
